# =============================================================================
# ASD Detection Backend - Example environment file
# =============================================================================
# Copy this file to backend/.env (or to .env at the repo root) and fill in the
# values for your environment. Never commit a real .env file to the repo.
# All settings are read by app/config.py via pydantic-settings.
# =============================================================================

# Deployment mode: development | staging | production
# Production locks down CORS and hides /docs.
ASD_ENV=development

# --- Authentication ---------------------------------------------------------
# Absolute path to a Firebase Admin service-account JSON file.
# In production prefer GOOGLE_APPLICATION_CREDENTIALS or the metadata server.
ASD_FIREBASE_CREDENTIALS_PATH=

# Firebase project ID. When set, verified tokens whose `aud` claim does not
# match this value are rejected (defence in depth on top of signature check).
ASD_FIREBASE_PROJECT_ID=

# --- HTTP / CORS ------------------------------------------------------------
# Comma-separated list of allowed origins. Wildcard ("*") is rejected when
# ASD_ENV=production. Add your real frontend origin(s) here.
ASD_CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://10.0.2.2:8081

# Hard ceiling on request body size (bytes). Default = 25 MB.
ASD_MAX_REQUEST_BODY_BYTES=26214400

# --- Per-UID rate limiting (PR-C) ------------------------------------------
# Toggle the limiter completely. Defaults to true; set to false in single-user
# load tests.
ASD_RATE_LIMIT_ENABLED=true
# Heavy ML endpoints (/eye-tracking, /speech, /report/generate).
ASD_RATE_LIMIT_HEAVY_PER_MINUTE=12
ASD_RATE_LIMIT_HEAVY_PER_HOUR=120
# Light endpoints (/mcq).
ASD_RATE_LIMIT_LIGHT_PER_MINUTE=60
ASD_RATE_LIMIT_LIGHT_PER_HOUR=600

# --- Inference timeouts (PR-C) ---------------------------------------------
# Hard wall-clock cap per ML inference call (seconds). 504 on miss.
ASD_INFERENCE_TIMEOUT_SECONDS=45
# Maximum number of concurrent inference calls per process. 503 on overflow.
ASD_INFERENCE_MAX_CONCURRENT=4

# --- Logging (PR-E) --------------------------------------------------------
ASD_LOG_LEVEL=INFO
ASD_LOG_REDACT_PAYLOADS=true
# Output format: 'json' (one structured object per line, recommended for log
# aggregators), 'text' (human-readable), or 'auto' which picks json in
# production and text otherwise.
ASD_LOG_FORMAT=auto

# --- Eye-tracking model (PR-2) ---------------------------------------------
# Active backend: 'new_model' (trained 14-feature MLP, default) or
# 'legacy_mediapipe' (rule-based fallback).
EYE_TRACKING_BACKEND=new_model
# Pre-processing strategy when 'new_model' is selected:
#   'domain_adapt'        (default) — Per-feature affine map from the
#                         MediaPipe input distribution to the trained
#                         eye-tracker space, then the trained scaler.
#                         Uses ``mediapipe_stats.npz`` shipped alongside
#                         the model. Falls back to online_standardize
#                         if that artefact is missing.
#   'online_standardize'  — Per-batch z-score. Used when the trained
#                         decision boundary is not trusted on the
#                         current input.
#   'trained_scaler'      — Apply the saved StandardScaler directly.
#                         Only correct when the input matches the real
#                         eye-tracker training distribution; saturates
#                         at P(ASD) ≈ 1.0 on MediaPipe inputs.
#   'none'                — Debug only.
EYE_TRACKING_PREPROC=domain_adapt
