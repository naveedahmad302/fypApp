rules_version = '2';

// =========================================================================
// Firestore security rules
//
// Goals:
//   * Deny by default (no rule = no access).
//   * Every collection is scoped to an authenticated UID.
//   * Profiles, assessments, reports and uploaded files are readable and
//     writeable only by their owner.
//   * Chat messages are readable by every authenticated user (so the
//     community feed works) but only the original author may edit or
//     delete their own messages. Authorship is keyed by `userUid`,
//     matching the schema written by the GroupChat screens.
//   * No collection name is derived from user input — only the explicit
//     names enumerated below are reachable via these rules.
//   * Document-shape validation runs on every write so a malicious
//     client cannot poison a document with extra/typo'd fields.
// =========================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------
    // Helper functions
    // -----------------------------------------------------------------

    // Caller is signed in.
    function isSignedIn() {
      return request.auth != null;
    }

    // Caller owns the document keyed by `uid`.
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Returns the resource's userUid field (null-safe).
    // The frontend writes userUid (see GroupChatScreen.tsx) so this is
    // the canonical owner field for chat messages.
    function existingAuthor() {
      return resource != null && 'userUid' in resource.data
        ? resource.data.userUid
        : null;
    }

    // Caller is the original author of the chat message.
    function isMessageAuthor() {
      return isSignedIn() && request.auth.uid == existingAuthor();
    }

    // String validation helper. Allows non-empty strings up to maxLen.
    function isShortString(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }

    // Optional string — either absent or a string up to maxLen chars.
    function isOptionalShortString(data, key, maxLen) {
      return !(key in data) || (data[key] is string && data[key].size() <= maxLen);
    }

    // Validates the shape of a chat message at create-time. The frontend
    // (GroupChatScreen.tsx, RealTimeGroupChatScreen.tsx) writes:
    //   { text, userUid, userName, createdAt, image? }
    // We accept either a populated text OR a populated image, both must
    // sit alongside the canonical author / display fields.
    function isValidChatMessage(data) {
      return data.userUid is string && data.userUid == request.auth.uid
        && data.userName is string && data.userName.size() > 0 && data.userName.size() <= 120
        // createdAt is a server timestamp — enforce on create only.
        && (
          (isShortString(data.text, 4000)) ||
          ('image' in data && data.image is string && data.image.size() > 0 && data.image.size() <= 4096)
        )
        && isOptionalShortString(data, 'text', 4000)
        && isOptionalShortString(data, 'image', 4096);
    }

    // -----------------------------------------------------------------
    // /users/{userId}
    // Personal profile. Strictly readable/writable by the owner only.
    // -----------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSelf(userId);

      allow create: if isSelf(userId)
        && request.resource.data.uid == userId
        && isShortString(request.resource.data.email, 254)
        && isShortString(request.resource.data.fullName, 120);

      allow update: if isSelf(userId)
        // Owner cannot rewrite their own UID or createdAt timestamp.
        && (!('uid' in request.resource.data) ||
             request.resource.data.uid == resource.data.uid)
        && (!('createdAt' in request.resource.data) ||
             request.resource.data.createdAt == resource.data.createdAt);

      allow delete: if isSelf(userId);

      // -------------------------------------------------------------
      // /users/{userId}/<owned-subcollection>/{docId}
      // All assessment / report / upload data is nested under the owner
      // so ownership is enforced by the path alone.
      // -------------------------------------------------------------
      match /assessments/{assessmentId} {
        allow read, write: if isSelf(userId);
      }
      match /reports/{reportId} {
        allow read, write: if isSelf(userId);
      }
      match /uploads/{uploadId} {
        allow read, write: if isSelf(userId);
      }
      match /predictions/{predictionId} {
        allow read, write: if isSelf(userId);
      }
    }

    // -----------------------------------------------------------------
    // Community chat collections.
    //
    // Two explicitly-named collections are exposed. New ones must be
    // added here; arbitrary names are not reachable.
    // -----------------------------------------------------------------
    match /parents_support_circle/{messageId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && isValidChatMessage(request.resource.data);

      // Only the original author may edit their own message; they cannot
      // rewrite the userUid (== authorship) or createdAt timestamp.
      allow update: if isMessageAuthor()
        && request.resource.data.userUid == resource.data.userUid
        && (!('createdAt' in request.resource.data) ||
             request.resource.data.createdAt == resource.data.createdAt)
        && isOptionalShortString(request.resource.data, 'text', 4000)
        && isOptionalShortString(request.resource.data, 'image', 4096);

      allow delete: if isMessageAuthor();
    }

    match /weekly_check_ins/{messageId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && isValidChatMessage(request.resource.data);

      allow update: if isMessageAuthor()
        && request.resource.data.userUid == resource.data.userUid
        && (!('createdAt' in request.resource.data) ||
             request.resource.data.createdAt == resource.data.createdAt)
        && isOptionalShortString(request.resource.data, 'text', 4000)
        && isOptionalShortString(request.resource.data, 'image', 4096);

      allow delete: if isMessageAuthor();
    }

    // -----------------------------------------------------------------
    // Default deny — anything not matched above is rejected.
    // -----------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
