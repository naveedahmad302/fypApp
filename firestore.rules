rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ==========================================
    // Helper Functions
    // ==========================================

    // Check if the request comes from an authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the authenticated user owns the given userId
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validate that a chat message has correct structure and sender identity.
    // Supports two client patterns:
    //   1) GroupChatScreen:       { text|image, userUid, userName, createdAt }
    //   2) RealTimeGroupChatScreen (GiftedChat): { text, user, createdAt }
    function isValidChatCreate() {
      let data = request.resource.data;

      // Pattern 1 – GroupChatScreen (text or image message)
      let isGroupChat = data.keys().hasOnly(['text', 'image', 'userUid', 'userName', 'createdAt'])
        && data.userUid == request.auth.uid
        && data.userName is string
        && data.userName.size() > 0
        && data.userName.size() <= 100
        && (
          ('text' in data && data.text is string && data.text.size() > 0 && data.text.size() <= 5000)
          || ('image' in data && data.image is string && data.image.size() > 0 && data.image.size() <= 2000)
        );

      // Pattern 2 – RealTimeGroupChatScreen / GiftedChat
      let isGiftedChat = data.keys().hasOnly(['text', 'user', 'createdAt'])
        && 'user' in data
        && data.user._id == request.auth.uid
        && data.text is string
        && data.text.size() > 0
        && data.text.size() <= 5000;

      return data.createdAt == request.time
        && (isGroupChat || isGiftedChat);
    }

    // Check ownership of an existing chat message (handles both formats)
    function isChatMessageOwner() {
      return ('userUid' in resource.data && resource.data.userUid == request.auth.uid)
        || ('user' in resource.data && resource.data.user._id == request.auth.uid);
    }

    // ==========================================
    // User Profiles
    // ==========================================
    match /users/{userId} {
      // Any authenticated user can read profiles (needed for chat display names)
      allow read: if isAuthenticated();

      // Only the owner can create their profile with required fields
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly(
          ['uid', 'email', 'fullName', 'phoneNumber', 'dateOfBirth',
           'location', 'profileImage', 'showToCommunity', 'showActivity', 'createdAt']
        )
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() > 0
        && request.resource.data.fullName.size() <= 200
        && request.resource.data.createdAt == request.time;

      // Only the owner can update; uid, email, and createdAt are immutable
      allow update: if isOwner(userId)
        && request.resource.data.keys().hasOnly(
          ['uid', 'email', 'fullName', 'phoneNumber', 'dateOfBirth',
           'location', 'profileImage', 'showToCommunity', 'showActivity', 'createdAt']
        )
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt;

      // Disallow client-side profile deletion
      allow delete: if false;
    }

    // ==========================================
    // Parents Support Circle Chat
    // ==========================================
    match /parents_support_circle/{messageId} {
      // Any authenticated user can read messages
      allow read: if isAuthenticated();

      // Validated create – enforces sender identity, required fields, and size limits
      allow create: if isAuthenticated() && isValidChatCreate();

      // Only the message author can update their own message;
      // ownership fields (userUid / user._id) are immutable
      allow update: if isAuthenticated()
        && isChatMessageOwner()
        && (
          (!('userUid' in resource.data) || request.resource.data.userUid == resource.data.userUid)
          && (!('user' in resource.data) || request.resource.data.user._id == resource.data.user._id)
        );

      // Only the message author can delete their own message
      allow delete: if isAuthenticated() && isChatMessageOwner();
    }

    // ==========================================
    // Weekly Check-Ins Chat
    // ==========================================
    match /weekly_check_ins/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidChatCreate();
      allow update: if isAuthenticated()
        && isChatMessageOwner()
        && (
          (!('userUid' in resource.data) || request.resource.data.userUid == resource.data.userUid)
          && (!('user' in resource.data) || request.resource.data.user._id == resource.data.user._id)
        );
      allow delete: if isAuthenticated() && isChatMessageOwner();
    }

    // ==========================================
    // Connection Test (debug / health-check utility)
    // ==========================================
    match /connection_test/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ==========================================
    // Deny everything else by default
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
