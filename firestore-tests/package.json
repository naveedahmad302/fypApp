{
  "name": "firestore-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Firestore security-rules emulator tests for fypApp.",
  "scripts": {
    "test": "jest --runInBand",
    "test:emulator": "firebase --project=demo-fypapp-test emulators:exec --only firestore --import=./.emulator-data --export-on-exit=./.emulator-data 'jest --runInBand'"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/**/*.test.ts"
    ],
    "testTimeout": 30000
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.40",
    "firebase": "^11.10.0",
    "firebase-tools": "^14.27.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  }
}
